<UserControl x:Class="WinHyperland.AnimationsSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#99282830"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style x:Key="SettingName" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="PresetRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="6" Padding="12,8"
                                BorderThickness="1" BorderBrush="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse x:Name="RadioDot" Width="16" Height="16"
                                         Stroke="#88FFFFFF" StrokeThickness="1.5"
                                         Fill="Transparent" VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioDot" Property="Fill" Value="#FF0078D7"/>
                                <Setter TargetName="RadioDot" Property="Stroke" Value="#FF0078D7"/>
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel.Resources>
            <Style TargetType="Border" BasedOn="{StaticResource CardBorder}"/>
        </StackPanel.Resources>

        <!-- Card 1: Animation Style -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Animation Style" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- Radio buttons for presets -->
                <StackPanel x:Name="PresetPanel">
                    <RadioButton x:Name="RadioIsland" Style="{StaticResource PresetRadio}"
                                 GroupName="AnimPreset" Checked="Preset_Checked" Tag="Island">
                        <StackPanel>
                            <TextBlock Text="Island" FontWeight="Bold" FontSize="13"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       Foreground="White"/>
                            
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="RadioFluid" Style="{StaticResource PresetRadio}"
                                 GroupName="AnimPreset" Checked="Preset_Checked" Tag="Fluid">
                        <StackPanel>
                            <TextBlock Text="Fluid" FontWeight="Bold" FontSize="13"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       Foreground="White"/>
                            
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="RadioSmooth" Style="{StaticResource PresetRadio}"
                                 GroupName="AnimPreset" Checked="Preset_Checked" Tag="Smooth">
                        <StackPanel>
                            <TextBlock Text="Smooth" FontWeight="Bold" FontSize="13"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       Foreground="White"/>
                            
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="RadioSnappy" Style="{StaticResource PresetRadio}"
                                 GroupName="AnimPreset" Checked="Preset_Checked" Tag="Snappy">
                        <StackPanel>
                            <TextBlock Text="Snappy" FontWeight="Bold" FontSize="13"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       Foreground="White"/>
                            
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="RadioInstant" Style="{StaticResource PresetRadio}"
                                 GroupName="AnimPreset" Checked="Preset_Checked" Tag="Instant">
                        <StackPanel>
                            <TextBlock Text="Instant" FontWeight="Bold" FontSize="13"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       Foreground="White"/>
                            
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Live preview strip -->
                <Border Margin="0,16,0,0" Background="#10FFFFFF" CornerRadius="8"
                        Padding="16,20" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Preview" FontSize="11" Foreground="#88FFFFFF"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Border x:Name="PreviewPill" Width="100" Height="28"
                                CornerRadius="14" Background="#FF000000"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Card 2: Individual Effects -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Individual Effects" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- Note for Instant mode -->
                <Border x:Name="InstantModeNote" Visibility="Collapsed"
                        Background="#30FF6B6B" CornerRadius="4" Padding="10,6"
                        Margin="0,0,0,8">
                    <TextBlock Text="Disabled in Instant mode"
                               FontSize="11" Foreground="#FFFF9999"
                               FontFamily="Segoe UI Variable Text, Segoe UI"/>
                </Border>

                <StackPanel x:Name="EffectsPanel">
                    <!-- Enable Animations Toggle -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Enable Animations" Style="{StaticResource SettingName}"/>
                            
                        </StackPanel>
                        <CheckBox x:Name="TogglePillMorph" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="TogglePillMorph_Changed"
                                  Unchecked="TogglePillMorph_Changed"/>
                    </Grid>

                    <!-- Content Crossfade -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Content Crossfade" Style="{StaticResource SettingName}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToggleCrossfade" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ToggleCrossfade_Changed"
                                  Unchecked="ToggleCrossfade_Changed"/>
                    </Grid>

                    <!-- Waveform Bars -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Waveform Bars" Style="{StaticResource SettingName}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToggleWaveform" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ToggleWaveform_Changed"
                                  Unchecked="ToggleWaveform_Changed"/>
                    </Grid>

                    <!-- Notification Drop -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Notification Drop" Style="{StaticResource SettingName}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToggleNotifDrop" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ToggleNotifDrop_Changed"
                                  Unchecked="ToggleNotifDrop_Changed"/>
                    </Grid>

                    <!-- Expand on Media Change -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Expand on Media Change" Style="{StaticResource SettingName}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToggleExpandMedia" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ToggleExpandMedia_Changed"
                                  Unchecked="ToggleExpandMedia_Changed"/>
                    </Grid>

                    <!-- Keyline Pulse -->
                    <Grid Style="{StaticResource ToggleRow}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Keyline Pulse" Style="{StaticResource SettingName}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ToggleKeylinePulse" Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ToggleKeylinePulse_Changed"
                                  Unchecked="ToggleKeylinePulse_Changed"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
