<UserControl x:Class="WinHyperisland.FeaturesSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#99282830"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style x:Key="SettingName" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Card 1: System Integration -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="System Integration" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- Media playback integration -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Media playback integration"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <CheckBox x:Name="ToggleMedia" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="ToggleMedia_Changed"
                              Unchecked="ToggleMedia_Changed"/>
                </Grid>

                <!-- Notification integration -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Notification integration"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <CheckBox x:Name="ToggleNotifications" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="ToggleNotifications_Changed"
                              Unchecked="ToggleNotifications_Changed"/>
                </Grid>

                <!-- Launch on startup -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Launch on Windows startup"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <CheckBox x:Name="ToggleStartup" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="ToggleStartup_Changed"
                              Unchecked="ToggleStartup_Changed"/>
                </Grid>

                <Border Style="{StaticResource Separator}"/>

                <!-- Weather integration -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Weather integration"
                                   Style="{StaticResource SettingName}"/>
                        <TextBlock Text="Shows live weather in the pill (auto-detects your city)"
                                   Style="{StaticResource SettingDesc}"/>
                    </StackPanel>
                    <CheckBox x:Name="ToggleWeather" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="ToggleWeather_Changed"
                              Unchecked="ToggleWeather_Changed"/>
                </Grid>

                <!-- Temperature unit -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Temperature unit"
                                   Style="{StaticResource SettingName}"/>
                    </StackPanel>
                    <ComboBox x:Name="TempUnitCombo" Grid.Column="1"
                              Width="80" VerticalAlignment="Center"
                              Background="#40FFFFFF" Foreground="White"
                              FontFamily="Segoe UI Variable Text, Segoe UI"
                              FontSize="13"
                              SelectionChanged="TempUnitCombo_Changed">
                        <ComboBoxItem Content="°C" Tag="C"/>
                        <ComboBoxItem Content="°F" Tag="F"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Card 2: Timing -->
        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Timing" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- Notification display duration -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Notification display duration (seconds)"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <TextBox x:Name="NotifDurationInput" Grid.Column="1"
                             Width="70" VerticalAlignment="Center"
                             Background="#40FFFFFF" Foreground="White"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="13" Padding="8,4"
                             LostFocus="NotifDurationInput_LostFocus"/>
                </Grid>

                <!-- Collapse delay -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Collapse delay after media pause (seconds)"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <TextBox x:Name="CollapseDelayInput" Grid.Column="1"
                             Width="70" VerticalAlignment="Center"
                             Background="#40FFFFFF" Foreground="White"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="13" Padding="8,4"
                             LostFocus="CollapseDelayInput_LostFocus"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Card 3: Live Status -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Live Status" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- Current media display -->
                <Border Background="#15FFFFFF" CornerRadius="6" Padding="12,10"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatusAppIcon" Grid.Column="0"
                                Width="32" Height="32" CornerRadius="6"
                                Background="#20FFFFFF" Margin="0,0,10,0"
                                VerticalAlignment="Center" ClipToBounds="True">
                            <Image x:Name="StatusIconImage" Stretch="UniformToFill"
                                   Width="32" Height="32"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusTrackTitle" Text="No media playing"
                                       Style="{StaticResource SettingName}"/>
                            
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Refresh" Style="{StaticResource ActionButton}"
                            Margin="0,0,8,0" Click="RefreshStatus_Click"/>
                    <Button Content="Test Notification" Style="{StaticResource ActionButton}"
                            Click="TestNotification_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
