<UserControl x:Class="WinHyperisland.ExclusionsSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#99282830"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#30FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#50FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RemoveButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#30FF6B6B"/>
            <Setter Property="BorderBrush" Value="#40FF6B6B"/>
        </Style>
        <Style x:Key="ExclusionItem" TargetType="Border">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Card 1: Excluded Applications -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Excluded Applications" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                

                <!-- Exclusions list -->
                <StackPanel x:Name="ExclusionsList" Margin="0,0,0,12"/>

                <!-- Empty state -->
                <Border x:Name="EmptyState" Background="#10FFFFFF"
                        CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
                    <TextBlock Text="No excluded apps. All apps will be shown."
                               FontSize="12" Foreground="#66FFFFFF"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Add button -->
                <Button Content="+ Add App" Style="{StaticResource ActionButton}"
                        HorizontalAlignment="Left" Click="AddApp_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
