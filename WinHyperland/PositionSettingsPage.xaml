<UserControl x:Class="WinHyperland.PositionSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="White">
    <UserControl.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#99282830"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="Separator" TargetType="Border">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#80FFFFFF"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style x:Key="SettingName" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#88FFFFFF"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

    </UserControl.Resources>

    <StackPanel Width="Auto">
        <!-- Card 1: Screen Position -->
        <Border Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Screen Position" Style="{StaticResource GroupTitle}"/>
                <Border Style="{StaticResource Separator}"/>

                <!-- ScreenPosition ComboBox -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Position" Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <ComboBox x:Name="PositionCombo" Grid.Column="1"
                              VerticalAlignment="Center"
                              SelectionChanged="PositionCombo_SelectionChanged">
                        <ComboBoxItem Content="Top Center"/>
                        <ComboBoxItem Content="Top Left"/>
                        <ComboBoxItem Content="Top Right"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>
                </Grid>

                <!-- Target Monitor ComboBox -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Target Monitor" Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <ComboBox x:Name="MonitorCombo" Grid.Column="1"
                              MinWidth="180" VerticalAlignment="Center"
                              SelectionChanged="MonitorCombo_SelectionChanged">
                        <!-- Populated dynamically in code-behind -->
                    </ComboBox>
                </Grid>

                <!-- Horizontal Offset (X axis) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Horizontal Offset (X axis)" Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <TextBox x:Name="CustomXInput" Grid.Column="1"
                             Width="100" VerticalAlignment="Center"
                             Background="#40FFFFFF" Foreground="White"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="13" Padding="8,4"
                             LostFocus="CustomXInput_LostFocus"
                             KeyDown="CustomXInput_KeyDown"/>
                </Grid>

                <!-- PillVerticalOffset (Y axis) -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Vertical Offset (Y axis)"
                                   Style="{StaticResource SettingName}"/>
                        
                    </StackPanel>
                    <TextBox x:Name="VerticalOffsetInput" Grid.Column="1"
                             Width="100" VerticalAlignment="Center"
                             Background="#40FFFFFF" Foreground="White"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="13" Padding="8,4"
                             LostFocus="VerticalOffsetInput_LostFocus"
                             KeyDown="VerticalOffsetInput_KeyDown"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
